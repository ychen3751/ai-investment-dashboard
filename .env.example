# ─── Application ───────────────────────────────────────────────────────
APP_NAME=AI Investment Dashboard
DEBUG=true                          # Set false in production

# ─── Database (PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=investor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=investment_dashboard

# Railway: set DATABASE_URL to the Railway PostgreSQL connection string.
# Local Docker: uses the values above.
DATABASE_URL=postgresql+asyncpg://investor:changeme@postgres:5432/investment_dashboard
DATABASE_URL_SYNC=postgresql://investor:changeme@postgres:5432/investment_dashboard

# ─── Redis (optional in production — cache degrades gracefully) ───────
REDIS_URL=redis://redis:6379/0

# ─── Auth 🔐 ──────────────────────────────────────────────────────────
# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_ANALYSIS=10/minute

# ─── External APIs (optional) ─────────────────────────────────────────
OPENAI_API_KEY=
POLYGON_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins.  Production example:
#   https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Server ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173
# Railway injects PORT automatically; this is the fallback.
PORT=8000

# ─── Frontend (used by Vite at build time) ────────────────────────────
# In production (Vercel), set this to your Railway backend URL, e.g.:
#   https://your-app.railway.app/api
VITE_API_BASE_URL=/api
