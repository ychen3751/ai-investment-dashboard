# Application
APP_NAME=AI Investment Dashboard
DEBUG=true

# Database
POSTGRES_USER=investor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=investment_dashboard
DATABASE_URL=postgresql+asyncpg://investor:changeme@postgres:5432/investment_dashboard
DATABASE_URL_SYNC=postgresql://investor:changeme@postgres:5432/investment_dashboard

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=generate-a-random-256-bit-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_ANALYSIS=10/minute

# External APIs
POLYGON_API_KEY=placeholder_polygon_api_key
OPENAI_API_KEY=placeholder_openai_api_key

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
