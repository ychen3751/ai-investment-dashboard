# ─── Frontend Environment Variables ─────────────────────────────────────
# These are prefixed with VITE_ so Vite exposes them to the client at build time.

# Production API Base URL
# In dev (Docker), this defaults to /api which proxies to http://backend:8000.
# In production (Vercel), set this to your Railway backend URL, e.g.:
#   https://your-app.railway.app/api
VITE_API_BASE_URL=/api
